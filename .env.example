# Microsoft OAuth token endpoint for the tenant used by this member.
AUTH_REFRESH_URL=https://login.microsoftonline.com/f418be65-463f-4812-9f50-027d4927970a/oauth2/v2.0/token
AUTH_REFRESH_CONTENT_TYPE=application/x-www-form-urlencoded

# Teams APIs
SEARCH_API_URL=https://substrate.office.com/searchservice/api/v2/query
PARENT_SEARCH_METHOD=substrate
LIST_POSTS_API_BASE_URL=https://teams.cloud.microsoft/api/csa/apac/api/v1/containers
POST_API_BASE_URL=https://teams.cloud.microsoft/api/chatsvc/apac/v1/users/ME/conversations

# Scheduler and token keepalive
REPORT_TIMEZONE=Asia/Bangkok
WATCH_INTERVAL_MINUTES=1
TOKEN_REFRESH_BEFORE_HOURS=8
BROWSER_RENEW_BEFORE_HOURS=8
BROWSER_RENEW_RETRY_MINUTES=60
AUTO_BROWSER_RENEW=true

# Browser-based refresh-token renewal
BROWSER_RENEW_START_URL=https://teams.cloud.microsoft/
BROWSER_RENEW_TYPE=chromium
BROWSER_RENEW_HEADLESS=false
BROWSER_RENEW_CHANNEL=chrome
BROWSER_RENEW_TIMEOUT_MS=600000
BROWSER_RENEW_SCOPE="openid profile offline_access"

# Posting defaults (member config can override these)
PARENT_POST_AFTER_TIME=17:25
REPORT_POST_RANDOM_WINDOW_MINUTES=0

# Concurrency and retry defaults
RUN_LOCK_STALE_MINUTES=240
PARENT_POST_LOCK_TIMEOUT_MS=120000
PARENT_POST_LOCK_RETRY_MS=1000
PARENT_SEARCH_RETRY_COUNT=3
PARENT_SEARCH_RETRY_MS=2000
LIST_POSTS_PAGE_SIZE=50
LIST_POSTS_MAX_PAGES=5
REPLY_CHECK_PAGE_SIZE=200

# Optional fallbacks. Authentication data is currently stored per member in
# members/<member_id>/config.json, so these should normally remain unset.
# TEAMS_ACCESS_TOKEN=
# AUTH_REFRESH_TOKEN=
# AUTH_LOGIN_URL=
# AUTH_USERNAME=
# AUTH_EMAIL=
# AUTH_PASSWORD=
